{
  "name": "web2app",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "workspaces": [
    "web",
    "server",
    "template"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:web\"",
    "dev:web": "npm run dev -w web",
    "dev:server": "npm run dev -w server",
    "build": "npm run build -w web && npm run build -w server",
    "start": "npm run start -w server"
  },
  "devDependencies": {
    "adm-zip": "^0.5.17",
    "concurrently": "^9.1.2",
    "typescript": "~5.6.2"
  }
}
